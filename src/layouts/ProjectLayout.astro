---
import BaseLayout from "./BaseLayout.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import "../styles/projects.css";

/* ✅ URLs bundleadas por Vite */
import igCarouselUrl from "../scripts/ig-carousel.js?url";
import projectRevealUrl from "../scripts/project-reveal.js?url";

const { title = "Project", description = "" } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <header class="siteNav">
    <div class="container siteNav__inner">
      <a class="siteNav__brand" href="/" aria-label="Home">
        <img class="siteNav__logo siteNav__logo--light" src="/logo-gsusgil-red.svg" alt="gsusgil" />
        <img class="siteNav__logo siteNav__logo--dark"  src="/logo-gsusgil.svg" alt="gsusgil" />
      </a>

      <nav class="siteNav__actions" aria-label="Primary">
        <a class="btn" href="/">Home</a>
        <ThemeToggle />
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <!-- ✅ Scripts de proyectos -->
  <script type="module" src={igCarouselUrl}></script>
  <script type="module" src={projectRevealUrl}></script>
</BaseLayout>