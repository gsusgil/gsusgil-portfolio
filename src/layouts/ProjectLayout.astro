---
import BaseLayout from "./BaseLayout.astro";
import ThemeToggle from "../components/ThemeToggle.astro";

/*
  CSS viejo principal.
  Lo mantenemos por ahora para no romper proyectos existentes.
*/
import "../styles/projects.css";

/*
  Nueva estructura modular.
  Estos archivos van después para poder sobrescribir projects.css
  mientras migramos módulo por módulo.
*/
import "../styles/projects/project-base.css";
import "../styles/projects/visual-hero.css";
import "../styles/projects/case-overview.css";
import "../styles/projects/project-carousel.css";
import "../styles/projects/project-email.css";
import "../styles/projects/project-media.css";
import "../styles/projects/more-projects.css";

const { title = "Project", description = "" } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <header class="siteNav">
    <div class="container siteNav__inner">
      <a class="siteNav__brand" href="/" aria-label="Home">
        <img
          class="siteNav__logo siteNav__logo--light"
          src="/logo-gsusgil-red.svg"
          alt="gsusgil"
        />
        <img
          class="siteNav__logo siteNav__logo--dark"
          src="/logo-gsusgil.svg"
          alt="gsusgil"
        />
      </a>

      <nav class="siteNav__actions" aria-label="Primary">
        <a class="btn" href="/">Home</a>
        <ThemeToggle />
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <script>
    import "../scripts/ig-carousel.js";
    import "../scripts/project-reveal.js";
  </script>
</BaseLayout>