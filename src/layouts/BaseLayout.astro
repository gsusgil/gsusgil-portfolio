---
/* src/layouts/BaseLayout.astro */
import "../styles/global.css";
import "../styles/components.css";

import ResumeModal from "../components/ResumeModal.astro";

/**
 * ✅ IMPORTANTÍSIMO:
 * - Estos imports con ?url hacen que Vite los bundlee y Astro los sirva como /_astro/xxxx.js
 * - Así NO aparece el error "Failed to resolve module specifier lenis/gsap" en Vercel.
 */
import themeUrl from "../scripts/theme.js?url";
import modalUrl from "../scripts/modal.js?url";

const { title = "Portfolio", description = "Lorem ipsum portfolio." } = Astro.props;
---

<!doctype html>
<html lang="es" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- ✅ Tema “instantáneo” (evita flash) -->
    <script>
      (function () {
        try {
          const savedTheme = localStorage.getItem("theme");
          const systemPrefersDark =
            window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches;

          const resolvedTheme = savedTheme ? savedTheme : (systemPrefersDark ? "dark" : "light");
          document.documentElement.setAttribute("data-theme", resolvedTheme);
        } catch (err) {}
      })();
    </script>
  </head>

  <body>
    <slot />
    <ResumeModal />

    <!-- ✅ Scripts globales (BUNDLEADOS) -->
    <script type="module" src={themeUrl}></script>
    <script type="module" src={modalUrl}></script>
  </body>
</html>