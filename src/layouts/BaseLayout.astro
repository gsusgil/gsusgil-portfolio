---
import "../styles/global.css";
import "../styles/components.css";

import ResumeModal from "../components/ResumeModal.astro";

/* ✅ URLs bundleadas por Vite (NO /scripts/...) */
import themeScriptUrl from "../scripts/theme.js?url";
import modalScriptUrl from "../scripts/modal.js?url";

const { title = "Portfolio", description = "Lorem ipsum portfolio." } = Astro.props;
---

<!doctype html>
<html lang="es" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Bootstrap theme instantáneo -->
    <script>
      (function () {
        try {
          const savedTheme = localStorage.getItem("theme");
          const systemPrefersDark =
            window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches;

          const resolvedTheme = savedTheme ? savedTheme : (systemPrefersDark ? "dark" : "light");
          document.documentElement.setAttribute("data-theme", resolvedTheme);
        } catch (err) {}
      })();
    </script>
  </head>

  <body>
    <slot />
    <ResumeModal />

    <!-- ✅ Scripts globales bundleados (Vercel + local OK) -->
    <script type="module" src={themeScriptUrl}></script>
    <script type="module" src={modalScriptUrl}></script>
  </body>
</html>