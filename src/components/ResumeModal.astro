<div class="modal" id="resumeModal" aria-hidden="true">
  <div class="modal__overlay" id="resumeOverlay" data-close-resume></div>

  <div
    class="modal__panel"
    role="dialog"
    aria-modal="true"
    aria-label="Resume PDF"
  >
    <div class="modal__bar">
      <strong>Resume</strong>

      <div class="modal__actions">
        <a
          class="btn"
          href="/resume/CV_JesusGil_GraphicDesigner.pdf"
          download="CV_JesusGil_GraphicDesigner.pdf"
        >
          Download
        </a>

        <button
          class="btn"
          id="closeResumeButton"
          type="button"
          data-close-resume
        >
          Close
        </button>
      </div>
    </div>

    <div class="modal__body">
      <iframe
        src="/resume/CV_JesusGil_GraphicDesigner.pdf#zoom=110"
        title="Resume PDF"
      ></iframe>
    </div>
  </div>
</div>