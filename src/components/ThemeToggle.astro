---
/* =========================================================
   THEME TOGGLE (UI)
   - Botón para alternar Dark/Light
========================================================= */
---

<div class="theme-toggle">
  <button class="btn" id="themeToggleButton" type="button" aria-label="Toggle theme">
    Theme
    <span class="small" id="themeToggleLabel">Dark</span>
  </button>
</div>