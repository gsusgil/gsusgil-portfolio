---
import ProjectLayout from "../../layouts/ProjectLayout.astro";
import { projects, getProjectBySlug } from "../../data/projects/index.js";

export async function getStaticPaths() {
  return projects.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const project = getProjectBySlug(slug);

if (!project) throw new Error("Project not found");

const pad2 = (n) => String(n).padStart(2, "0");
const more = projects.filter((p) => p.slug !== slug).slice(0, 3);

const visualHero = project.modules?.find((m) => m.type === "visualHero");
const caseOverview = project.modules?.find((m) => m.type === "caseOverview");

const contentModules =
  project.modules?.filter(
    (m) => m.type !== "visualHero" && m.type !== "caseOverview"
  ) ?? [];
---

<ProjectLayout title={project.title} description={project.lede}>
  <article class={`project project--${project.slug}`}>
    {visualHero && (
      <section class="visualHero" data-reveal>
        <div class="visualHero__inner">
          {visualHero.images?.map((item) => (
            <figure class="visualHero__card">
              <img src={item.src} alt={item.alt ?? ""} loading="eager" />
              <figcaption>{item.label}</figcaption>
            </figure>
          ))}
        </div>
      </section>
    )}

    <header class="project__header" data-reveal>
      <div class="small projects__kicker">{project.kicker ?? "Selected project"}</div>
      <h1 class="project__h1">{project.title}</h1>
      <p class="project__lede">{project.lede}</p>
    </header>

    {caseOverview && (
      <section class="project__block caseOverview" data-reveal>
        <div class="caseOverview__content">
          {caseOverview.eyebrow && (
            <div class="caseOverview__eyebrow">{caseOverview.eyebrow}</div>
          )}

          <p class="caseOverview__text">{caseOverview.text}</p>

          {caseOverview.facts?.length > 0 && (
            <div class="caseOverview__facts">
              {caseOverview.facts.map((item) => (
                <div class="caseOverview__fact">
                  <div class="caseOverview__factLabel">{item.label}</div>
                  <div class="caseOverview__factValue">{item.value}</div>
                </div>
              ))}
            </div>
          )}

          {caseOverview.metrics?.length > 0 && (
            <div class="caseOverview__metrics">
              {caseOverview.metrics.map((item) => (
                <div class="caseOverview__metric">
                  <div class="caseOverview__metricValue">{item.value}</div>
                  <div class="caseOverview__metricLabel">{item.label}</div>
                </div>
              ))}
            </div>
          )}
        </div>
      </section>
    )}

    {contentModules.map((m) => (
      <>
        {/* INTRO */}
        {m.type === "intro" && (
          <section class="project__block project__intro" data-reveal>
            <h2 class="project__introTitle">{m.title}</h2>

            <div class="project__introGrid">
              {m.sections?.map((s) => (
                <div class="project__introItem">
                  <div class="project__introLabel">{s.label}</div>
                  <p class="project__introText">{s.text}</p>
                </div>
              ))}
            </div>

            <hr class="project__divider" />

            <div class="project__introRole">
              <div class="project__introLabel">Scope</div>
              <p class="project__introText">{m.scope}</p>
            </div>
          </section>
        )}

        {/* TEXT */}
        {m.type === "text" && (
          <section class="project__block" data-reveal>
            <div class="project__introLabel">{m.h2}</div>
            <p class="project__introText">{m.p}</p>
          </section>
        )}

        {/* IMAGE */}
        {m.type === "image" && (
          <section class="project__block project__level" data-reveal>
            <div class="project__levelTop">
              {m.num && <div class="project__levelNum">{m.num}</div>}

              <div>
                <h2 class="project__h2">{m.h2}</h2>
                <p class="project__p">{m.p}</p>
              </div>
            </div>

            <img class="project__img" src={m.src} alt={m.alt ?? ""} loading="lazy" />
          </section>
        )}

        {/* EMAIL */}
        {m.type === "email" && (
          <section class="project__block project__level" data-reveal>
            <div class="project__levelTop">
              {m.num && <div class="project__levelNum">{m.num}</div>}

              <div class={`emailStage ${m.flip ? "emailStage--flip" : ""}`}>
                {!m.flip && (
                  <div class="emailStage__info">
                    {m.label && <p class="emailStage__label">{m.label}</p>}
                    <h2 class="emailStage__title">{m.h2}</h2>
                    {m.p && <p class="emailStage__text">{m.p}</p>}

                    {(m.metrics?.length > 0 || m.highlights?.length > 0) && (
                      <div class="emailStage__metaItem">
                        <div class="emailStage__metaLabel">Performance</div>

                        {m.metrics?.length > 0 && (
                          <div class="emailStage__stats">
                            {m.metrics.map((item) => (
                              <div class="emailStage__stat">
                                <div class="emailStage__statLabel">{item.label}</div>
                                <div class="emailStage__statValue">{item.value}</div>
                              </div>
                            ))}
                          </div>
                        )}

                        {m.highlights?.length > 0 && (
                          <div class="emailStage__highlights">
                            {m.highlights.map((item) => (
                              <p class="emailStage__highlight">{item}</p>
                            ))}
                          </div>
                        )}
                      </div>
                    )}

                    <div class="emailStage__meta">
                      {m.role && (
                        <div class="emailStage__metaItem">
                          <div class="emailStage__metaLabel">My Role</div>
                          <p class="emailStage__metaValue">{m.role}</p>
                        </div>
                      )}

                      {m.insight && (
                        <div class="emailStage__metaItem">
                          <div class="emailStage__metaLabel">Insight</div>
                          <p class="emailStage__metaValue">{m.insight}</p>
                        </div>
                      )}
                    </div>
                  </div>
                )}

                <figure class="emailStage__viewer">
                  <div class="emailStage__viewerBar">
                    <span class="emailStage__viewerDot"></span>
                    <span class="emailStage__viewerDot"></span>
                    <span class="emailStage__viewerDot"></span>
                    <p class="emailStage__viewerLabel">{m.viewerLabel ?? "Email preview"}</p>
                  </div>

                  <div class="emailStage__scroll">
                    <img
                      class="emailStage__img"
                      src={m.src}
                      alt={m.alt ?? ""}
                      loading="lazy"
                    />
                  </div>
                </figure>

                {m.flip && (
                  <div class="emailStage__info">
                    {m.label && <p class="emailStage__label">{m.label}</p>}
                    <h2 class="emailStage__title">{m.h2}</h2>
                    {m.p && <p class="emailStage__text">{m.p}</p>}

                    {(m.metrics?.length > 0 || m.highlights?.length > 0) && (
                      <div class="emailStage__metaItem">
                        <div class="emailStage__metaLabel">Performance</div>

                        {m.metrics?.length > 0 && (
                          <div class="emailStage__stats">
                            {m.metrics.map((item) => (
                              <div class="emailStage__stat">
                                <div class="emailStage__statLabel">{item.label}</div>
                                <div class="emailStage__statValue">{item.value}</div>
                              </div>
                            ))}
                          </div>
                        )}

                        {m.highlights?.length > 0 && (
                          <div class="emailStage__highlights">
                            {m.highlights.map((item) => (
                              <p class="emailStage__highlight">{item}</p>
                            ))}
                          </div>
                        )}
                      </div>
                    )}

                    <div class="emailStage__meta">
                      {m.role && (
                        <div class="emailStage__metaItem">
                          <div class="emailStage__metaLabel">My Role</div>
                          <p class="emailStage__metaValue">{m.role}</p>
                        </div>
                      )}

                      {m.insight && (
                        <div class="emailStage__metaItem">
                          <div class="emailStage__metaLabel">Insight</div>
                          <p class="emailStage__metaValue">{m.insight}</p>
                        </div>
                      )}
                    </div>
                  </div>
                )}
              </div>
            </div>
          </section>
        )}

        {/* CAROUSEL */}
        {m.type === "carousel" && (
          <section class="project__block project__level" data-reveal>
            <div class="project__levelTop">
              {m.num && <div class="project__levelNum">{m.num}</div>}

              <div class="project__stageWrap">
                <div class="project__stageHeader">
                  <h2 class="project__stageTitle">{m.stage}</h2>

                  <div class="project__stageKPI">
                    <div class="project__stageKPIValue">{m.metrics?.ctr}</div>
                    <div class="project__stageKPILabel">CTR</div>
                  </div>
                </div>

                <div class="project__stageStats" aria-label="Stage metrics">
                  <div class="project__stat">
                    <div class="project__statLabel">Impressions</div>
                    <div class="project__statValue">{m.metrics?.impressions}</div>
                  </div>

                  <div class="project__stat">
                    <div class="project__statLabel">Clicks</div>
                    <div class="project__statValue">{m.metrics?.clicks}</div>
                  </div>
                </div>

                <div class="project__stageDid">
                  <div class="project__stageDidLabel">Design decision</div>
                  <p class="project__stageDidText">{m.did}</p>
                </div>
              </div>
            </div>

            {m.layout === "grid" && (
              <div class="ig-grid" aria-label={m.stage}>
                {Array.from({ length: m.count }).map((_, i) => (
                  <figure class="ig-gridSlide">
                    <img
                      src={`${m.dir}/${pad2(i + 1)}.jpg`}
                      alt={`${m.stage} — slide ${i + 1}`}
                      loading="lazy"
                    />
                  </figure>
                ))}
              </div>
            )}

            {m.layout !== "grid" && (
              <div class="ig-scrollWrap" aria-label={m.stage}>
                <button class="ig-navBtn" type="button" aria-label="Previous" data-ig-prev>
                  ←
                </button>

                <div class="ig-scroll" data-ig-carousel>
                  {Array.from({ length: m.count }).map((_, i) => (
                    <figure class="ig-scrollSlide">
                      <img
                        src={`${m.dir}/${pad2(i + 1)}.jpg`}
                        alt={`${m.stage} — slide ${i + 1}`}
                        loading="lazy"
                      />
                    </figure>
                  ))}
                </div>

                <button class="ig-navBtn" type="button" aria-label="Next" data-ig-next>
                  →
                </button>
              </div>
            )}
          </section>
        )}

        {/* MEDIA PAIR */}
        {m.type === "mediaPair" && (
          <section class="project__block project__level" data-reveal>
            <div class="project__levelTop">
              {m.num && <div class="project__levelNum">{m.num}</div>}

              <div>
                <h2 class="project__h2">{m.h2}</h2>
                {m.p && <p class="project__p">{m.p}</p>}
              </div>
            </div>

            <div class="mediaPairGrid">
              {m.items?.map((item) => (
                <figure class="mediaPairGrid__item">
                  <div class="mediaPairGrid__media">
                    <img src={item.src} alt={item.alt ?? ""} loading="lazy" />
                  </div>

                  {item.caption && (
                    <figcaption class="mediaPairGrid__caption">{item.caption}</figcaption>
                  )}
                </figure>
              ))}
            </div>
          </section>
        )}

        {/* MEDIA FEATURE */}
        {m.type === "mediaFeature" && (
          <section class="project__block project__level" data-reveal>
            <div class="project__levelTop">
              {m.num && <div class="project__levelNum">{m.num}</div>}

              <div>
                <h2 class="project__h2">{m.h2}</h2>
                {m.p && <p class="project__p">{m.p}</p>}
              </div>
            </div>

            <div class="mediaFeature">
              <figure class="mediaFeature__imageItem">
                <div class="mediaFeature__imageMedia">
                  <img src={m.image.src} alt={m.image.alt ?? ""} loading="lazy" />
                </div>

                {m.image?.caption && (
                  <figcaption class="mediaFeature__caption">{m.image.caption}</figcaption>
                )}
              </figure>

              <figure class="mediaFeature__videoItem">
                <div class="mediaFeature__videoMedia">
                  <video
                    controls
                    playsinline
                    preload="metadata"
                    poster={m.video.poster}
                    src={m.video.src}
                  />
                </div>

                {m.video?.caption && (
                  <figcaption class="mediaFeature__caption">{m.video.caption}</figcaption>
                )}
              </figure>
            </div>
          </section>
        )}

        {/* MEDIA STACK */}
        {m.type === "mediaStack" && (
          <section class="project__block project__level" data-reveal>
            <div class="project__levelTop">
              {m.num && <div class="project__levelNum">{m.num}</div>}

              <div>
                <h2 class="project__h2">{m.h2}</h2>
                {m.p && <p class="project__p">{m.p}</p>}
              </div>
            </div>

            <div class="mediaStack">
              {m.items?.map((item) => (
                <figure class="mediaStack__item">
                  <div class="mediaStack__media">
                    <img src={item.src} alt={item.alt ?? ""} loading="lazy" />
                  </div>

                  {item.caption && (
                    <figcaption class="mediaStack__caption">{item.caption}</figcaption>
                  )}
                </figure>
              ))}
            </div>
          </section>
        )}

        {/* VIDEO */}
        {m.type === "video" && (
          <section class="project__block project__level" data-reveal>
            <h2 class="project__h2">{m.h2}</h2>
            <p class="project__p">{m.p}</p>

            <div class="videoPlaceholder">
              <img class="project__img" src={m.poster} alt={m.alt ?? ""} loading="lazy" />
              <div class="videoPlaceholder__badge">Video (placeholder)</div>
            </div>
          </section>
        )}
      </>
    ))}

    <section class="project__block moreProjects" data-reveal>
      <h2 class="project__h2">More projects</h2>

      <div class="moreProjects__grid">
        {more.map((p) => (
          <a class="moreCard" href={`/projects/${p.slug}`}>
            <div class="moreCard__thumb">
              <img src={p.preview} alt="" loading="lazy" />
            </div>

            <div class="moreCard__meta">
              <div class="moreCard__title">{p.title}</div>
              <div class="moreCard__lede">{p.lede}</div>
            </div>
          </a>
        ))}
      </div>
    </section>
  </article>
</ProjectLayout>