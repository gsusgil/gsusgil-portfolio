---
import ProjectLayout from "../../layouts/ProjectLayout.astro";
import { projects, getProjectBySlug } from "../../data/projects/index.js";

export async function getStaticPaths() {
  return projects.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const project = getProjectBySlug(slug);

if (!project) throw new Error("Project not found");

const pad2 = (n) => String(n).padStart(2, "0");
const more = projects.filter((p) => p.slug !== slug).slice(0, 3);
---

<ProjectLayout title={project.title} description={project.lede}>
  <article class="project">
    <header class="project__header" data-reveal>
      <div class="small projects__kicker">{project.kicker ?? "Selected project"}</div>
      <h1 class="project__h1">{project.title}</h1>
      <p class="project__lede">{project.lede}</p>
    </header>

    {project.modules?.map((m) => (
      <>
        {/* INTRO */}
        {m.type === "intro" && (
          <section class="project__block project__intro" data-reveal>
            <h2 class="project__introTitle">{m.title}</h2>

            <div class="project__introGrid">
              {m.sections?.map((s) => (
                <div class="project__introItem">
                  <div class="project__introLabel">{s.label}</div>
                  <p class="project__introText">{s.text}</p>
                </div>
              ))}
            </div>

            <hr class="project__divider" />

            <div class="project__introRole">
              <div class="project__introLabel">Scope</div>
              <p class="project__introText">{m.scope}</p>
            </div>
          </section>
        )}

        {/* STAGE (scoreboard limpio) */}
        {m.type === "stage" && (
  <section class="project__block project__stage" data-reveal>

    <div class="project__stageHeader">
      <div class="project__stageNum">
        {m.stage}
      </div>

      <div class="project__stageKPI">
        <div class="project__stageKPIValue">{m.metrics?.ctr}</div>
        <div class="project__stageKPILabel">CTR</div>
      </div>
    </div>

    <div class="project__stageStats">
      <div class="project__stat">
        <div class="project__statLabel">Impressions</div>
        <div class="project__statValue">{m.metrics?.impressions}</div>
      </div>
      <div class="project__stat">
        <div class="project__statLabel">Clicks</div>
        <div class="project__statValue">{m.metrics?.clicks}</div>
      </div>
      <div class="project__stat">
        <div class="project__statLabel">CTR</div>
        <div class="project__statValue">{m.metrics?.ctr}</div>
      </div>
    </div>

    <div class="project__stageDid">
      <div class="project__stageDidLabel">What I did</div>
      <p class="project__stageDidText">{m.did}</p>
    </div>

  </section>
)}

        {/* TEXT */}
        {m.type === "text" && (
  <section class="project__block" data-reveal>
      <div class="project__introLabel">{m.h2}</div>
      <p class="project__introText">{m.p}</p>
    </div>
  </section>
)}

        {/* IMAGE */}
        {m.type === "image" && (
          <section class="project__block project__level" data-reveal>
            <div class="project__levelTop">
              {m.num && <div class="project__levelNum">{m.num}</div>}
              <div>
                <h2 class="project__h2">{m.h2}</h2>
                <p class="project__p">{m.p}</p>
              </div>
            </div>

            <img class="project__img" src={m.src} alt={m.alt ?? ""} loading="lazy" />
          </section>
        )}

        {/* CAROUSEL */}
        {m.type === "carousel" && (
  <section class="project__block project__level" data-reveal>
    {/* Header: número + stage + KPI */}
    <div class="project__levelTop">
      {m.num && <div class="project__levelNum">{m.num}</div>}

      <div class="project__stageWrap">
        <div class="project__stageHeader">
          <h2 class="project__stageTitle">{m.stage}</h2>

          <div class="project__stageKPI">
            <div class="project__stageKPIValue">{m.metrics?.ctr}</div>
            <div class="project__stageKPILabel">CTR</div>
          </div>
        </div>

        <div class="project__stageStats" aria-label="Stage metrics">
          <div class="project__stat">
            <div class="project__statLabel">Impressions</div>
            <div class="project__statValue">{m.metrics?.impressions}</div>
          </div>
          <div class="project__stat">
            <div class="project__statLabel">Clicks</div>
            <div class="project__statValue">{m.metrics?.clicks}</div>
          </div>
          <div class="project__stat">
            <div class="project__statLabel">CTR</div>
            <div class="project__statValue">{m.metrics?.ctr}</div>
          </div>
        </div>

        <div class="project__stageDid">
          <div class="project__stageDidLabel">What I did</div>
          <p class="project__stageDidText">{m.did}</p>
        </div>
      </div>
    </div>

    {/* Carrusel */}
    {m.layout === "grid" && (
      <div class="ig-grid" aria-label={m.stage}>
        {Array.from({ length: m.count }).map((_, i) => (
          <figure class="ig-gridSlide">
            <img
              src={`${m.dir}/${pad2(i + 1)}.jpg`}
              alt={`${m.stage} — slide ${i + 1}`}
              loading="lazy"
            />
          </figure>
        ))}
      </div>
    )}

    {m.layout !== "grid" && (
      <div class="ig-scrollWrap" aria-label={m.stage}>
        <button class="ig-navBtn" type="button" aria-label="Previous" data-ig-prev>
          ←
        </button>

        <div class="ig-scroll" data-ig-carousel>
          {Array.from({ length: m.count }).map((_, i) => (
            <figure class="ig-scrollSlide">
              <img
                src={`${m.dir}/${pad2(i + 1)}.jpg`}
                alt={`${m.stage} — slide ${i + 1}`}
                loading="lazy"
              />
            </figure>
          ))}
        </div>

        <button class="ig-navBtn" type="button" aria-label="Next" data-ig-next>
          →
        </button>
      </div>
    )}
  </section>
)}

        {/* VIDEO */}
        {m.type === "video" && (
          <section class="project__block project__level" data-reveal>
            <h2 class="project__h2">{m.h2}</h2>
            <p class="project__p">{m.p}</p>

            <div class="videoPlaceholder">
              <img class="project__img" src={m.poster} alt={m.alt ?? ""} loading="lazy" />
              <div class="videoPlaceholder__badge">Video (placeholder)</div>
            </div>
          </section>
        )}
      </>
    ))}

    <section class="project__block moreProjects" data-reveal>
      <h2 class="project__h2">More projects</h2>

      <div class="moreProjects__grid">
        {more.map((p) => (
          <a class="moreCard" href={`/projects/${p.slug}`}>
            <div class="moreCard__thumb">
              <img src={p.preview} alt="" loading="lazy" />
            </div>
            <div class="moreCard__meta">
              <div class="moreCard__title">{p.title}</div>
              <div class="moreCard__lede">{p.lede}</div>
            </div>
          </a>
        ))}
      </div>
    </section>
  </article>
</ProjectLayout>